{
  "name": "qiniso-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Qiniso — the deterministic fact-verification layer for AI agents (monorepo).",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:modules": "npm run build -w @qiniso/identifiers -w @qiniso/network -w @qiniso/finance -w @qiniso/crypto -w @qiniso/national-id -w @qiniso/academic -w @qiniso/locale -w @qiniso/vat",
    "build": "npm run build:modules && npm run build -w qiniso",
    "test": "npm run test --workspaces --if-present",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.6.0"
  }
}
