    "ean",
    "iban",
    "vat",
    "national-id",
    "kyc",
    "pesel",
    "codice-fiscale",
    "tckn"
  ],
  "license": "Apache-2.0",
  "author": "Qiniso",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@noble/hashes": "^1.3.3",
    "@scure/base": "^1.1.6",
    "date-holidays": "^3.23.0",
    "jsvat-next": "^2.5.0",
    "libphonenumber-js": "^1.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@qiniso/academic": "*",
    "@qiniso/crypto": "*",
    "@qiniso/finance": "*",
    "@qiniso/identifiers": "*",
    "@qiniso/locale": "*",
    "@qiniso/national-id": "*",
    "@qiniso/network": "*",
    "@qiniso/vat": "*",
    "tsup": "^8.3.0"
  }
